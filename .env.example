# ===================
# 服务器配置
# ===================
PORT=8000

# ===================
# API 配置
# ===================
# API 端点地址
API_ENDPOINT=https://chat.z.ai/api/v2/chat/completions

# 认证令牌：登录管理后台 /admin 的"主密钥"
# 推荐设一个强密码。登录后台后可以创建任意数量的子 API Key 给客户端用
# 多个用逗号分隔
AUTH_TOKEN=sk-your-master-token

# Captcha Provider 地址
# 用于自动获取阿里云验证码 token
CAPTCHA_PROVIDER_URL=http://127.0.0.1:9876

# Z.AI JWT Token (多账号轮换)
# 已废弃：建议用后台 /admin 添加，可动态增删
# BACKUP_TOKEN=

# ===================
# 功能配置
# ===================
# 调试日志
DEBUG_LOGGING=false

# 工具调用支持（GLM 模型对此不稳定，详见 README）
TOOL_SUPPORT=true

# 强制把 auto/未指定的 tool_choice 升级为 required
FORCE_TOOL_CHOICE_REQUIRED=false

# 请求失败时的重试次数（不含首次请求）
RETRY_COUNT=5

# 跳过认证令牌验证（开放访问，不推荐）
SKIP_AUTH_TOKEN=false

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===================
# 显示配置
# ===================
# 备注信息，在 / 端点显示
NOTE=
